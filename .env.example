# Django runtime
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=replace-with-a-secure-secret
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
DJANGO_CORS_ALLOWED_ORIGIN_REGEXES=
DJANGO_CORS_ALLOW_ALL=False
FRONTEND_BASE_URL=http://127.0.0.1:5173
# Production example:
# FRONTEND_BASE_URL=https://it-random.onrender.com
DEMO_PASSWORD_RESET_LINKS=False
DRF_THROTTLE_ANON=120/min
DRF_THROTTLE_USER=240/min
DRF_THROTTLE_AUTH=20/min
DRF_THROTTLE_PASSWORD_RESET=10/min

# Demo reset defaults
DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_EMAIL=admin@example.com
DEMO_ADMIN_PASSWORD=Admin123456!

# Frontend (used by Vite when needed)
VITE_API_BASE_URL=http://127.0.0.1:8000/api
# Production example:
# VITE_API_BASE_URL=https://it-random-api.onrender.com/api
